{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/todo"
      }
    }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/index.html$",
      "dest": "/index.html"
    },
    {
      "src": "^/.+$",
      "dest": "/index.html"
    }
  ]
}
